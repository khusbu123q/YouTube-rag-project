# Cell 1 - Setup and Documents
from langchain_huggingface import HuggingFaceEmbeddings
from langchain_chroma import Chroma
from langchain_core.documents import Document

embedding = HuggingFaceEmbeddings(model_name="sentence-transformers/all-MiniLM-L6-v2")

# Create documents
doc1 = Document(
    page_content="Machine Learning algorithms help computers learn from data and make predictions without being explicitly programmed.",
    metadata={"source": "article_ml_basics", "topic": "ML", "year": 2024}
)
doc2 = Document(
    page_content="Electric vehicles are becoming more popular as battery technology improves and charging infrastructure expands globally.",
    metadata={"source": "ev_report", "topic": "Technology", "year": 2023}
)
doc3 = Document(
    page_content="Blockchain technology provides a decentralized and secure way to record transactions across multiple computers.",
    metadata={"source": "blockchain_blog", "topic": "Technology", "year": 2024}
)
doc4 = Document(
    page_content="Yoga and meditation have proven benefits for reducing stress, improving focus, and enhancing overall mental wellbeing.",
    metadata={"source": "wellness_magazine", "topic": "Health", "year": 2022}
)
doc5 = Document(
    page_content="The James Webb Space Telescope is capturing images of galaxies billions of light years away, revealing secrets of the early universe.",
    metadata={"source": "nasa_journal", "topic": "Space", "year": 2025}
)

vector_store = Chroma(
    embedding_function=embedding,
    persist_directory='chroma_db',
    collection_name='sample'
)

docs = [doc1, doc2, doc3, doc4, doc5]
